# ----------------------------------------------------------------
# Local development (SQLite — zero setup)
# ----------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ----------------------------------------------------------------
# Production (Vercel) — Postgres
# ----------------------------------------------------------------
# On Vercel: add a Postgres database via Storage → Postgres
# (Neon-powered, free tier 0.5 GB). Vercel auto-provisions
# DATABASE_URL — overwrite the value above. Format:
#   postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# ----------------------------------------------------------------
# Session signing — 32+ random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# ----------------------------------------------------------------
SESSION_SECRET="please-change-me-to-a-32-byte-random-string-please-change-me"

# ----------------------------------------------------------------
# Public dashboard URL — used by extension Test button + report
# downloads. On Vercel: set to https://your-deployment.vercel.app
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
