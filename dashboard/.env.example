# Local development uses SQLite by default. For production, point to PostgreSQL.
DATABASE_URL="file:./dev.db"

# 32+ random bytes used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET="please-change-me-to-a-32-byte-random-string-please-change-me"

# Public dashboard URL (used for the extension to know where to ingest).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
